# Razorpay API credentials (from Dashboard → Account & Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# Razorpay webhook secret (from Dashboard → Account & Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Razorpay subscription plan IDs (create via Dashboard → Subscriptions → Plans)
# RAZORPAY_PLAN_ID_30=plan_xxxxxxxxxxxxxxx
# RAZORPAY_PLAN_ID_15=plan_xxxxxxxxxxxxxxx
